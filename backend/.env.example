PORT=3001
HOST=0.0.0.0
UPLOAD_DIR=./uploads
DATA_DIR=./data

# Postgres (opcional; sin DATABASE_URL usa file-store local)
# DATABASE_URL=postgres://andreu:andreu@postgres:5432/andreu

GOOGLE_CLOUD_PROJECT=kiev-prueba
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=

# Beraldi custom extractor
DOCUMENT_AI_CUSTOM_BERALDI_ID=
DOCUMENT_AI_BERALDI_VERSION=

# TSB custom extractor
DOCUMENT_AI_CUSTOM_TSB_ID=
DOCUMENT_AI_TSB_VERSION=

# Corina / Quilmes custom extractor (viajes cortos)
DOCUMENT_AI_CUSTOM_CORINA_ID=
DOCUMENT_AI_CORINA_VERSION=

# Google Maps — Geocoding + Places (agente Destinos)
GOOGLE_MAPS_API_KEY=

# Notas de voz WhatsApp — OpenAI (recomendado) + fallback Google Speech
# OPENAI_API_KEY=sk-...
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# OPENAI_TRANSCRIBE_TIMEOUT_MS=25000
# SPEECH_LANGUAGE_CODE=es-419
# SPEECH_ENABLED=true

# Service account JSON en una línea (recomendado en Easypanel)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Correcciones WhatsApp — Gemini interpreta lenguaje natural si el parser regex no alcanza
# CORRECCION_IA_ENABLED=true
# GEMINI_LOCATION=us-central1
# GEMINI_CORRECCION_MODEL=gemini-2.5-flash
# CORRECCION_IA_TIMEOUT_MS=12000

# Opcional — solo si querés forzar tenant sin OCR:
# BUILDERBOT_DEFAULT_TENANT=tsb
# TENANT_BY_PHONE_JSON={"5492616168767":"tsb"}
# Un solo bot BB: ver docs/builderbot-andreu.md (proyecto Andreu Remitos)
# BUILDERBOT_BOT_ID=
# BUILDERBOT_API_KEY=

# Bot Baileys self-hosted (bot/ en este repo) — alternativa a BuilderBot Cloud
# Bot Baileys principal (mensajes salientes / monitor)
# BAILEYS_BOT_URL=http://localhost:3008
# Bot Baileys solo para pantalla vincular.nivel41.com (sesión aparte)
# VINCULAR_BAILEYS_BOT_URL=http://andreu-bot-vincular:3008
# BUILDERBOT_WEBHOOK_SILENT=false

# Auth — usuarios plataforma (operador | supervisor | administrador)
# AUTH_JWT_SECRET=generar-un-secreto-largo-en-produccion
# AUTH_SEED_ADMIN_USER=admin
# AUTH_SEED_ADMIN_PASSWORD=admin123

# API externa planillas (JSON) — header X-Api-Key
# EXTERNAL_API_KEYS_JSON=[{"id":"tsb-prod","name":"TSB integración","tenant":"tsb","key":"andreu_tsb_live_…","scopes":["planillas:read"]}]
