# Local: API en 3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Easypanel (frontend): URL interna del servicio API en la misma red Docker
# Ejemplo si el servicio API se llama "andreu" en Easypanel:
# API_INTERNAL_URL=http://andreu:3001
#
# Si no está definida, el navegador usa /backend (proxy del frontend).
